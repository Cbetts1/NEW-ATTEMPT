# AI Aura OS — Environment Configuration
# File: env/aios.env
#
# These constants define the OS's self-contained runtime environment.
# They are consumed by the build system and kernel configuration.

# OS identity
AIOS_NAME=AI Aura OS
AIOS_VERSION=1.0.0
AIOS_ARCH=i386

# Memory layout (all values in hex)
AIOS_BOOT_LOAD_ADDR=0x7C00
AIOS_KERNEL_LOAD_ADDR=0x10000
AIOS_HEAP_START=0x300000
AIOS_HEAP_SIZE_KB=4096
AIOS_STACK_TOP=0x200000

# Disk image geometry
AIOS_IMG_SECTORS=2880
AIOS_SECTOR_SIZE=512
AIOS_KERNEL_MAX_SECTORS=64

# Feature flags
AIOS_ENABLE_VGA=1
AIOS_ENABLE_MIRROR=1
AIOS_ENABLE_PLUGINS=1
AIOS_ENABLE_EVENT_BUS=1
